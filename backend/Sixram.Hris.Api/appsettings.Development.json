{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=SixramDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "SecretKey": "SixramDevelopmentOnlySuperSecretSigningKey1234567890",
    "Issuer": "Sixram.Hris.Api",
    "Audience": "Sixram.Hris.Web",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "RefreshTokenCookieName": "sixram_refresh_token"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "EmployeeDocuments": {
    "StorageRootPath": "App_Data/employee-documents",
    "MaxFileSizeMb": 10,
    "ExpiringSoonDays": 30,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  },
  "Attendance": {
    "TimeZoneId": "Singapore Standard Time",
    "DashboardTrendDays": 7,
    "MaxQueryRangeDays": 31
  },
  "Leave": {
    "StorageRootPath": "App_Data/leave-attachments",
    "MaxAttachmentSizeMb": 10,
    "ExpiringSoonDays": 30,
    "UpcomingWindowDays": 14,
    "LowBalanceThreshold": 1,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
